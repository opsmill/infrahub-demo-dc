# =============================================================================
# Infrahub Configuration
# =============================================================================

# Infrahub API server address
# Used by CLI tools and local scripts to connect to Infrahub
# Note: The Service Catalog container uses http://infrahub-server:8000 automatically
# via docker-compose.override.yml for proper Docker networking
export INFRAHUB_ADDRESS=http://localhost:8000

# Infrahub UI URL for browser links
# Used by the Service Catalog to generate clickable links to Infrahub UI pages
# Should be the URL accessible from your browser (typically http://localhost:8000)
export INFRAHUB_UI_URL=http://localhost:8000

# Infrahub API authentication token
# Generate a token in the Infrahub UI under Settings > API Tokens
export INFRAHUB_API_TOKEN=06438eb2-8019-4776-878c-0941b1f1d1ec

# Infrahub version to use
# Specify the version of Infrahub to run (e.g., 1.5.1, stable, latest)
# export INFRAHUB_VERSION=1.6.0

# Enable Infrahub Enterprise features
# Set to "true" to enable enterprise features, "false" for community edition
export INFRAHUB_ENTERPRISE=false

# Use local git repository instead of GitHub
# Set to "true" to mount the current directory as the git repository in Infrahub
# This is useful for local development and testing of generator/transform changes
# When enabled:
#   - Infrahub will use /upstream (the mounted current directory) as the repo
#   - Bootstrap script loads objects/git-repo/local-dev.yml
# When disabled (default):
#   - Infrahub will clone from GitHub
#   - Bootstrap script loads objects/git-repo/github.yml
export INFRAHUB_GIT_LOCAL=false

# =============================================================================
# Parallel Instance Configuration
# =============================================================================
# Use these settings to run multiple instances of this project simultaneously.
# Each instance needs a unique project name and different ports.
#
# Example for a second instance:
#   INFRAHUB_PROJECT_NAME=infrahub-2
#   INFRAHUB_PORT=8100
#   PREFECT_PORT=4201
#   STREAMLIT_PORT=8502
#   INFRAHUB_ADDRESS=http://localhost:8100
#   INFRAHUB_UI_URL=http://localhost:8100

# Docker Compose project name (defaults to directory name)
# export INFRAHUB_PROJECT_NAME=infrahub-demo-dc

# Port mappings for Docker services
# export INFRAHUB_PORT=8000
# export PREFECT_PORT=4200
# export STREAMLIT_PORT=8501

# =============================================================================
# Service Catalog Configuration
# =============================================================================

# Enable the Service Catalog Streamlit application
# Set to "true" to start the service catalog container with 'uv run invoke start'
# Set to "false" (default) to run only the core Infrahub services
# The service catalog provides a web UI for managing data center deployments
export INFRAHUB_SERVICE_CATALOG=false

# Default branch to use when the service catalog application starts
# This is the branch that will be selected by default in the UI
export DEFAULT_BRANCH=main

# Time to wait (in seconds) for the Infrahub generator to complete after creating a DC
# Increase this value if your generators take longer to complete
export GENERATOR_WAIT_TIME=60

# API request timeout in seconds
# Maximum time to wait for API requests to complete
export API_TIMEOUT=30

# Number of retry attempts for failed API requests
# The service catalog will retry failed requests this many times before giving up
export API_RETRY_COUNT=3

# =============================================================================
# Webhook Firewall Demo (profile: webhook-demo)
# =============================================================================
# These variables are consumed only when the `webhook-demo` compose profile is
# active (brought up by `invoke demo-webhook-up` or the per-externality tasks).
# Every value below is an obviously-demo default — the whole lab is local-only
# (containerlab on this machine) so these are safe to commit. Override any of
# them via shell export if you want to substitute.
#
# IMPORTANT: Run the webhook demo with `export INFRAHUB_GIT_LOCAL=true` so
# Infrahub registers this working tree (which carries the webhook transforms
# in its .infrahub.yml) via the already-configured /upstream mount. No
# separate git server is required.

# Shared secret the webhook listener validates against the Infrahub
# CoreCustomWebhook's `shared_key`. Must match on both sides.
export WEBHOOK_LISTENER_SHARED_KEY=demo-shared-key

# Host port the listener service binds on the host (container side is always 8001).
export WEBHOOK_LISTENER_PORT=8001

# VyOS login — used by the listener's ansible inventory to reach fw1.
export VYOS_SSH_USER=admin
export VYOS_SSH_PASS=demo-vyos-password

# =============================================================================
# Additional Notes
# =============================================================================
#
# 1. Copy this file to .env and update the values as needed
# 2. The .env file is gitignored and will not be committed to version control
# 3. For Docker Compose deployments, these variables can also be set in
#    docker-compose.override.yml under the environment section
# 4. Some variables (like INFRAHUB_ADDRESS) may need different values depending
#    on whether you're running locally or in Docker:
#    - Local development: http://localhost:8000
#    - Docker container: http://infrahub-server:8000
#
